# Local dev (default): SQLite file in BACKEND/data/
# DATABASE_URL=sqlite:///./data/dev.db

# Render PostgreSQL (use External URL from laptop; Internal URL on Render backend service)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST.virginia-postgres.render.com/DATABASE

DATABASE_URL=sqlite:///./data/dev.db
JWT_SECRET=change-me-in-production
ADMIN_SECRET=change-me-admin-secret
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://50-points.vercel.app
CORS_ORIGIN_REGEX=https://.*\.vercel\.app
ENVIRONMENT=development
# Optional: The Racing API (https://www.theracingapi.com) — best quality public racing data
RACING_API_USERNAME=
RACING_API_PASSWORD=
